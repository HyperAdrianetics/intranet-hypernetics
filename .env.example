# ===== Producción (Vercel + Neon) =====
# Cadena de conexión Neon (Postgres serverless). En Vercel: Project Settings > Environment Variables.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# DB_ADAPTER deja sin definir (o "neon") para usar el driver serverless de Neon.

# ===== Local (Docker, para pruebas) =====
DATABASE_URL="postgresql://cotizador:cotizador@localhost:5434/cotizador"
DB_ADAPTER=pg
